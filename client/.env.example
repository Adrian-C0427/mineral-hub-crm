# Base URL of the API. In dev, leave blank to use the Vite proxy (/api -> localhost:4000).
# In production (Railway), set to the API service's public URL, e.g. https://mineral-hub-api.up.railway.app
VITE_API_BASE=

# Dev-only: where the Vite proxy forwards /api
VITE_PROXY_TARGET=http://localhost:4000

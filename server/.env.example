# --- Core ---
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/mineralhub

# Secret used to sign session JWTs. Generate a long random string in production.
# Production REQUIRES this (>=32 chars) — the server refuses to boot with the default.
JWT_SECRET=change-me-to-a-long-random-string

# Dedicated key for encrypting integration credentials at rest (AES-256-GCM).
# REQUIRED in production (>=32 chars), separate from JWT_SECRET so rotating the
# session key never orphans stored credentials. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_SECRET_KEY=

# --- Auth / cookies ---
COOKIE_NAME=mh_session
SESSION_TTL_HOURS=168
# Set true in production: cross-subdomain services need SameSite=None; Secure.
COOKIE_CROSS_SITE=false

# --- CORS ---
# Comma-separated list of allowed frontend origins (the Vite dev server / Railway frontend URL)
CORS_ORIGINS=http://localhost:5173

# --- File storage (AWS S3 or S3-compatible) ---
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional, for R2/Backblaze/MinIO:
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL_SECONDS=300
MAX_UPLOAD_BYTES=26214400

# --- Outbound email (SMTP; e.g. Resend, Postmark, SES, Gmail) ---
# Feature is inert until HOST/USER/PASS are set. For Resend:
#   SMTP_HOST=smtp.resend.com  SMTP_USER=resend  SMTP_PASS=<resend api key>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Must be a verified sending domain (SPF/DKIM). May include a display name.
SMTP_FROM=Mineral Hub <no-reply@yourdomain.com>
SMTP_SECURE=false

# --- Error monitoring (Sentry; inert until DSN is set) ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Frontend build (set on the CLIENT service): the browser DSN + source-map upload.
# VITE_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# --- Bootstrap admin (optional, can also be entered interactively) ---
# ADMIN_NAME=
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

// Mineral Hub CRM — data model
// Ships with an EMPTY database (one bootstrapped Owner user via CLI). No seed data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  OWNER
  ASSOCIATE
}

enum UserStatus {
  ACTIVE
  DISABLED
}

// Organization membership role. Drives RBAC together with RolePermissions
// (per-org overrides of the code-defined defaults). OWNER implicitly has every
// permission and is the only role that can perform owner-only actions.
enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

enum Stage {
  UNDER_CONTRACT
  PREPARING_PACKAGE
  SENT_TO_BUYERS
  NEGOTIATING
  CLOSING
  CLOSED
  DEAD
}

// A Deal is either an acquisition OPPORTUNITY (default) or an OWNED_ASSET the
// company already holds. Owned assets reuse the entire Deal machinery (buyer
// matching, offers, activity, email, documents, map, pipeline) — the mineral-
// assets module is a filtered view over the same table, so nothing is duplicated.
enum RecordType {
  OPPORTUNITY
  OWNED_ASSET
}

// Operational mode for an OWNED_ASSET: HOLD (portfolio management) or SELL
// (actively marketed — behaves like an active deal while staying an owned asset).
enum AssetMode {
  HOLD
  SELL
}

enum SellerType {
  INDIVIDUAL
  TRUST
  LLC
  CORPORATION
  ESTATE
  PARTNERSHIP
  OTHER
}

enum RelationshipStatus {
  HOT
  WARM
  COLD
}

// Buyer activity response states. PENDING is the internal "logged, awaiting reply" state.
// LEGACY — superseded by BuyerStatus; kept additively for the backfill.
enum ResponseStatus {
  PENDING
  INTERESTED
  NOT_INTERESTED
  PASSED
  OFFER_MADE
}

// Buyer pipeline status within a deal (the actionable outreach lifecycle).
enum BuyerStatus {
  CONTACTED
  INTERESTED
  REVIEWING
  OFFER_RECEIVED
  NEGOTIATING
  PASSED
  CLOSED
}

// Communication-history entry types for the per-buyer deal timeline.
enum CommKind {
  EMAIL_OUT
  EMAIL_IN
  PHONE
  MEETING
  NOTE
  NEGOTIATION
  STATUS_CHANGE
}

enum OfferStatus {
  ACTIVE
  ACCEPTED
  REJECTED
  EXPIRED
  COUNTERED
  WITHDRAWN
}

enum FileCategory {
  PSA
  LPOA
  DEED
  PLAT_MAP
  TITLE_DOC
  OTHER
}

// ---------------------------------------------------------------------------
// Organizations (companies / shared workspaces)
// ---------------------------------------------------------------------------

model Organization {
  id        String   @id @default(cuid())
  name      String
  // Shareable, human-friendly Team ID. Acts as an always-valid reusable join key.
  teamId    String   @unique
  // Company branding: data-URL logos (PNG/SVG/JPG/WebP, size-capped). fullLogo =
  // expanded sidebar + report/PDF headers; compactLogo = collapsed sidebar icon.
  // Null → fall back to the default Mineral Hub / MH branding.
  fullLogo    String?
  compactLogo String?

  // --- Buyer Offering Portal (public marketplace) ---------------------------
  // portalSlug is the public URL key (/portal/:slug). Null → portal disabled
  // for the org. The legacy single-contact fields below are retained for
  // back-compat and lazily migrated into the first PortalContact row; new
  // contacts live in the PortalContact table (multi-contact, see below).
  portalSlug           String?  @unique
  portalEnabled        Boolean  @default(false)
  portalContactName    String?
  portalContactEmail   String?
  portalContactPhone   String?
  portalOfficeLocation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  deals             Deal[]
  buyers            Buyer[]
  activityLogs      ActivityLog[]
  inviteCodes       InviteCode[]
  expenses          Expense[]
  expenseCategories ExpenseCategory[]
  rolePermissions   RolePermissions[]
  buyerMessages     DealBuyerMessage[]
  emailTemplates    EmailTemplate[]
  integrations      Integration[]
  researchDocuments ResearchDocument[]
  researchPermits   ResearchPermit[]
  researchIngests   ResearchIngestRun[]
  researchWells     ResearchWell[]
  wellAnalyses      WellAnalysis[]
  notifications     Notification[]
  portalContacts    PortalContact[]
}

// A publishable contact card shown on the Buyer Offering Portal. An org can
// have any number; only `published` ones appear publicly, ordered by
// `sortOrder` with the single `isPrimary` contact first. `photo` is an optional
// data-URL headshot (size-capped like the org logos).
model PortalContact {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  title          String?
  email          String?
  phone          String?
  department     String?
  photo          String? // data URL, optional headshot
  isPrimary      Boolean      @default(false)
  published      Boolean      @default(true)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

// Public visibility of a published offering: PUBLIC appears in the marketplace;
// LINK_ONLY is reachable only via its unguessable share slug.
enum PortalVisibility {
  PUBLIC
  LINK_ONLY
}

// Lightweight in-app notification (portal leads today; general-purpose shape).
model Notification {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Targeted user; null = visible to any org admin/owner.
  userId         String?
  type           String // e.g. "portal_lead"
  title          String
  body           String?
  link           String? // in-app path, e.g. /buyers/:id
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([organizationId, readAt])
}

enum IntegrationStatus {
  NOT_CONNECTED
  CONNECTED
  ERROR
}

// Per-organization state for a third-party integration. The catalog (which
// providers exist, their category/description/auth type) lives in the client
// registry; this table only tracks connection status + non-secret config +
// sync metadata, so new providers need no schema change. Secure per-provider
// credential/OAuth handling is layered on later without changing this shape.
model Integration {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       String // registry key, e.g. "gmail", "quickbooks"
  status         IntegrationStatus @default(NOT_CONNECTED)
  config         Json? // non-secret settings (labels, sync schedule, etc.)
  connectedAt    DateTime?
  lastSyncAt     DateTime?
  lastError      String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([organizationId, provider])
  @@index([organizationId])
}

// Reusable outbound email template (org-shared). Supports {{tokens}} that are
// personalized per buyer at send time.
model EmailTemplate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  subject        String
  body           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

// Per-organization overrides of the default permission set for a role. Absence
// of a row means "use the code-defined defaults" (see domain/permissions.ts).
// OWNER is never stored here — it always has every permission.
model RolePermissions {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           OrgRole
  permissions    String[]
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, role])
  @@index([organizationId])
}

model InviteCode {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code            String       @unique
  // reusable=false => single-use (maxUses defaults to 1); reusable=true => many uses.
  reusable        Boolean      @default(false)
  active          Boolean      @default(true)
  maxUses         Int? // null = unlimited (reusable only)
  uses            Int          @default(0)
  createdByUserId String?
  createdAt       DateTime     @default(now())

  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------

model User {
  id           String     @id @default(cuid())
  name         String
  firstName    String?
  lastName     String?
  phone        String?
  email        String     @unique
  passwordHash String
  // Set when an owner resets this user's password; forces a change at next login.
  mustChangePassword Boolean @default(false)
  role         Role       @default(ASSOCIATE)
  status       UserStatus @default(ACTIVE)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  orgRole        OrgRole?

  // Two-factor auth (TOTP). Secret is base32; recovery codes are stored hashed.
  // NOTE: totpSecret is stored plaintext here — encrypt at rest before this
  // holds real accounts (see auth follow-ups).
  totpSecret        String?
  totpEnabled       Boolean  @default(false)
  totpRecoveryCodes String[] @default([])

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  // Last authenticated request (throttled). Powers "last activity" in the
  // member management view.
  lastActiveAt DateTime?

  passwordResetTokens PasswordResetToken[]
  oauthAccounts       OAuthAccount[]

  ownedDeals         Deal[]              @relation("DealRelationshipOwner")
  buyerOwnerships    BuyerOwner[]
  stageChanges       DealStageHistory[]
  sentActivities     DealBuyerActivity[] @relation("SentActivities")
  assignedActivities DealBuyerActivity[] @relation("AssignedActivities")
  authoredMessages   DealBuyerMessage[]  @relation("AuthoredMessages")
  uploadedFiles      FileAttachment[]
  activityLogs       ActivityLog[]
  expenses           Expense[]
  sellerAssignments  DealSeller[]        @relation("SellerAssignments")
  assignedDeals      Deal[]              @relation("DealAssignees")

  @@index([organizationId])
}

// Single-use, time-limited password reset token. Only the SHA-256 hash of the
// token is stored; the raw token lives only in the emailed link.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// A linked external identity (Google, Microsoft) for OAuth/SSO sign-in.
model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String // "google" | "microsoft"
  providerAccountId String // stable subject id from the provider
  email             String?
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Deals
// ---------------------------------------------------------------------------

model Deal {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  // Legacy free-text seller names. Structured seller records live in DealSeller.
  sellerNames    String[]

  // Opportunity vs. owned asset (see RecordType). Owned assets additionally
  // carry the ownership/financial fields below and an AssetMode.
  recordType RecordType @default(OPPORTUNITY)
  assetMode  AssetMode?

  // Deal characteristics support multiple selections (state stays single).
  counties       String[]
  // Primary state (kept for buyer matching / map back-compat) = states[0].
  state          String?
  // Multi-state selection (primary geographic filter). state stays synced to states[0].
  states         String[]
  acreageNma     Float?
  nra            Float?
  // Survey/abstracts this deal sits in (e.g. TX-289653). Links to map boundaries.
  abstractIds    String[]
  operator       String?
  // Ask Price = our asking price to buyers (marketing/list price).
  askPrice       Float?
  // Our Price = our acquisition cost (what the property is under contract for).
  // Cost basis for profit: profit = accepted offer - ourPrice - closing costs.
  ourPrice       Float?
  assetTypes     String[]
  basins         String[]
  formations     String[]

  stage                 Stage    @default(UNDER_CONTRACT)
  currentStageEnteredAt DateTime @default(now())
  deadReason            String?

  // Anchor dates. Effective Find-Buyer-By and Final-Closing are derived from
  // these unless an override is set. See server/src/domain/dates.ts (single resolver).
  dateUnderContract        DateTime?
  originalClosingDate      DateTime?
  findBuyerByDateOverride  DateTime?
  finalClosingDateOverride DateTime?

  selectedBuyerId String?
  selectedBuyer   Buyer?  @relation("SelectedBuyer", fields: [selectedBuyerId], references: [id], onDelete: SetNull)
  selectedOfferId String? @unique
  selectedOffer   Offer?  @relation("SelectedOffer", fields: [selectedOfferId], references: [id], onDelete: SetNull)

  relationshipOwnerId String?
  relationshipOwner   User?   @relation("DealRelationshipOwner", fields: [relationshipOwnerId], references: [id], onDelete: SetNull)

  estimatedClosingCosts Float?
  notes                 String?

  // --- Buyer Offering Portal -------------------------------------------------
  // Published deals appear on the public portal. portalSlug is an unguessable
  // share token (also the offering URL for LINK_ONLY deals). portalSummary is
  // the buyer-facing description — internal notes/pricing are never exposed.
  publishedToPortal Boolean          @default(false)
  portalSlug        String?          @unique
  portalVisibility  PortalVisibility @default(LINK_ONLY)
  portalFeatured    Boolean          @default(false)
  portalSummary     String?

  // --- Owned-asset fields (used when recordType = OWNED_ASSET) -------------
  // Ownership
  acquisitionDate    DateTime?
  purchasePrice      Float? // what we paid to acquire the asset
  currentValue       Float? // current estimated market value
  bookValue          Float? // carrying/book value
  ownershipStatus    String? // e.g. "Active", "Encumbered", "Leased"
  ownershipType      String? // e.g. "Mineral", "Royalty", "ORRI", "Working Interest"
  workingInterest    Float? // fraction 0–1
  netRevenueInterest Float? // fraction 0–1
  // Property (counties/abstractIds/basins/formations/operator/nra/acreageNma reused)
  surveys         String[]
  wells           String[] // well names / API numbers on the asset
  producingStatus String? // e.g. "Producing", "Shut-in", "Non-producing"
  // Financial
  royaltyIncomeAnnual Float? // estimated annual royalty income
  leaseStatus         String?
  leaseInfo           String?
  divisionOrdersNote  String?
  taxInfo             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stageHistory   DealStageHistory[]
  buyerActivity  DealBuyerActivity[]
  buyerMessages  DealBuyerMessage[]
  offers         Offer[]             @relation("DealOffers")
  files          FileAttachment[]
  activityLogs   ActivityLog[]
  sellers        DealSeller[]
  revenueEntries AssetRevenueEntry[]
  tracts         TractDescription[]
  // Team members assigned to this deal/asset (multi-assignee). relationshipOwner
  // is retained as the originating/primary owner for existing metrics & reports.
  assignees      User[]              @relation("DealAssignees")

  @@index([stage])
  @@index([selectedBuyerId])
  @@index([organizationId])
  @@index([organizationId, recordType])
  @@index([organizationId, publishedToPortal])
}

// A legal tract description on a deal. The raw text is authoritative; `parse`
// caches the machine reading of it (calls, refs, closure, warnings) and
// `geometry` the anchored GeoJSON polygon, both recomputed server-side whenever
// text or anchor change. Parsing is state-modular (see domain/tracts/) — TX
// metes-and-bounds first, other states plug into the registry later.
model TractDescription {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  name  String // "Tract 1", "160-acre Home Place", …
  text  String // legal description as pasted from the instrument
  state String @default("TX") // which parser grammar applies

  parse    Json? // ParsedTract: calls, refs, closure, computed acres, warnings
  geometry Json? // GeoJSON Feature (Polygon) once anchored; null until then
  // POB anchor: { lon, lat, source: "abstract" | "manual", abstractId? }.
  // "abstract" = auto-suggested from a parsed abstract reference; "manual" =
  // user placed/dragged the POB on the map (never overwritten by re-parse).
  anchor Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
}

// A structured seller/owner on a deal. Modeled as hasMany so a deal can grow to
// multiple owners, heirs, trusts and additional contacts without a schema change.
model DealSeller {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  isPrimary        Boolean @default(false)
  ownershipPercent Float? // this owner's share (for future multi-owner splits)

  // Personal
  firstName   String?
  middleName  String?
  lastName    String?
  companyName String?
  trustName   String?
  sellerType  SellerType @default(INDIVIDUAL)

  // Contact
  primaryPhone           String?
  secondaryPhone         String?
  email                  String?
  preferredContactMethod String? // "Phone" | "Email" | "Mail" | "Text"

  // Mailing address
  mailingAddress String?
  mailingCity    String?
  mailingState   String?
  mailingZip     String?

  // Physical address
  physicalAddress String?
  physicalCity    String?
  physicalState   String?
  physicalZip     String?

  // Additional
  internalNotes               String?
  taxId                       String? // sensitive — API only returns it with viewSellerTaxId
  preferredCommunicationNotes String?

  assignedTeamMemberId String?
  assignedTeamMember   User?   @relation("SellerAssignments", fields: [assignedTeamMemberId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
}

// A month of realized revenue on an owned asset (royalty, lease bonus, etc.).
model AssetRevenueEntry {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  month    DateTime // first day of the month, UTC
  amount   Float
  kind     String  @default("ROYALTY") // ROYALTY | LEASE_BONUS | OTHER
  operator String?
  note     String?

  createdAt DateTime @default(now())

  @@index([dealId, month])
}

model DealStageHistory {
  id              String   @id @default(cuid())
  dealId          String
  deal            Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fromStage       Stage?
  toStage         Stage
  changedByUserId String?
  changedBy       User?    @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)
  deadReason      String?
  createdAt       DateTime @default(now())

  @@index([dealId])
}

// ---------------------------------------------------------------------------
// Buyers
// ---------------------------------------------------------------------------

model Buyer {
  id                 String             @id @default(cuid())
  organizationId     String?
  organization       Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name               String
  companyName        String
  contactName        String?
  email              String?
  phone              String?
  website            String?
  mailingAddress     String?
  relationshipStatus RelationshipStatus @default(WARM)
  lastContactDate    DateTime?
  nextFollowUpDate   DateTime?
  notes              String?
  active             Boolean            @default(true)

  // Normalized company name for dedup (lowercased/trimmed/punct-stripped).
  normalizedCompany String

  // Known alternate spellings/aliases (e.g. discovered during research imports),
  // used to strengthen duplicate detection and shown on the profile.
  aliases String[] @default([])
  // Provenance: "research" marks a profile created/enriched from public-record
  // research so it can be flagged for manual completion. null = user-created.
  source String?
  // Research-derived enrichment that doesn't map to structured fields (counties/
  // states of activity, abstracts, common transaction types, counts, first/last
  // seen). Appended additively — never overwrites user-entered data.
  researchSummary Json?

  // Buyer Offering Portal lead capture: when the profile was created/updated by
  // a portal submission, and whether a fuzzy match needs a human duplicate check.
  portalSubmittedAt DateTime?
  duplicateReview   Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyBox        BuyBoxCriteria?
  owners        BuyerOwner[]
  tags          BuyerTagOnBuyer[]
  dealActivity  DealBuyerActivity[]
  buyerMessages DealBuyerMessage[]
  offers        Offer[]             @relation("BuyerOffers")
  selectedFor   Deal[]              @relation("SelectedBuyer")
  files         FileAttachment[]
  activityLogs  ActivityLog[]

  @@index([normalizedCompany])
  @@index([email])
  @@index([organizationId])
}

model BuyBoxCriteria {
  id         String   @id @default(cuid())
  buyerId    String   @unique
  buyer      Buyer    @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  states     String[]
  counties   String[]
  basins     String[]
  formations String[]
  assetTypes String[]
  minAcreage Float?
  maxAcreage Float?
  minPrice   Float?
  maxPrice   Float?
}

model BuyerOwner {
  buyerId String
  buyer   Buyer  @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([buyerId, userId])
}

model BuyerTag {
  id     String            @id @default(cuid())
  name   String            @unique
  buyers BuyerTagOnBuyer[]
}

model BuyerTagOnBuyer {
  buyerId String
  buyer   Buyer    @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  tagId   String
  tag     BuyerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([buyerId, tagId])
}

// ---------------------------------------------------------------------------
// Deal <-> Buyer marketing activity (the permanent marketing log)
// ---------------------------------------------------------------------------

model DealBuyerActivity {
  id                   String         @id @default(cuid())
  dealId               String
  deal                 Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  buyerId              String
  buyer                Buyer          @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  dateSent             DateTime?
  // Legacy status (kept additively; superseded by `status`). Backfilled → status.
  responseStatus       ResponseStatus @default(PENDING)
  // New buyer pipeline status. Nullable so the startup backfill fills existing
  // rows from responseStatus exactly once (idempotent: WHERE status IS NULL).
  status               BuyerStatus?
  offerAmount          Float?
  responseReceived     Boolean        @default(false)
  lastActivityDate     DateTime?
  nextFollowUpDate     DateTime?
  notes                String?
  sentByUserId         String?
  sentBy               User?          @relation("SentActivities", fields: [sentByUserId], references: [id], onDelete: SetNull)
  assignedTeamMemberId String?
  assignedTeamMember   User?          @relation("AssignedActivities", fields: [assignedTeamMemberId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages DealBuyerMessage[]

  @@unique([dealId, buyerId])
  @@index([buyerId])
}

// Communication-history timeline entry for a buyer within a deal. Emails
// (EMAIL_OUT/EMAIL_IN) group into threads via threadId; manual entries
// (PHONE/MEETING/NOTE/NEGOTIATION) and STATUS_CHANGE build the interaction log.
model DealBuyerMessage {
  id              String             @id @default(cuid())
  organizationId  String?
  organization    Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dealId          String
  deal            Deal               @relation(fields: [dealId], references: [id], onDelete: Cascade)
  buyerId         String
  buyer           Buyer              @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  activityId      String?
  activity        DealBuyerActivity? @relation(fields: [activityId], references: [id], onDelete: Cascade)
  kind            CommKind
  subject         String?
  body            String?
  occurredAt      DateTime           @default(now())
  createdByUserId String?
  createdBy       User?              @relation("AuthoredMessages", fields: [createdByUserId], references: [id], onDelete: SetNull)
  threadId        String?

  createdAt DateTime @default(now())

  @@index([dealId, buyerId])
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Offers (supports counter-chains)
// ---------------------------------------------------------------------------

model Offer {
  id             String      @id @default(cuid())
  dealId         String
  deal           Deal        @relation("DealOffers", fields: [dealId], references: [id], onDelete: Cascade)
  buyerId        String
  buyer          Buyer       @relation("BuyerOffers", fields: [buyerId], references: [id], onDelete: Cascade)
  amount         Float
  dateSubmitted  DateTime    @default(now())
  conditions     String?
  expirationDate DateTime?
  status         OfferStatus @default(ACTIVE)
  parentOfferId  String?
  parentOffer    Offer?      @relation("OfferCounters", fields: [parentOfferId], references: [id], onDelete: SetNull)
  counters       Offer[]     @relation("OfferCounters")
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  selectedOnDeal Deal? @relation("SelectedOffer")

  @@index([dealId])
  @@index([buyerId])
}

// ---------------------------------------------------------------------------
// Files (S3) — exactly one of dealId / buyerId is set
// ---------------------------------------------------------------------------

model FileAttachment {
  id               String       @id @default(cuid())
  dealId           String?
  deal             Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  buyerId          String?
  buyer            Buyer?       @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  // Legacy fixed category, kept for back-compat. The folder-based document
  // manager uses `folder` (a free string) so new folders need no schema change.
  category         FileCategory @default(OTHER)
  folder           String       @default("Other")
  filename         String
  mimeType         String
  sizeBytes        Int
  s3Key            String
  // Approved for buyers: shows up (and is downloadable) on the deal's public
  // offering page while the deal is published. Default private.
  visibleToBuyers  Boolean      @default(false)
  uploadedByUserId String?
  uploadedBy       User?        @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())
  // @default(now()) backfills existing rows; @updatedAt maintains it thereafter.
  updatedAt        DateTime     @default(now()) @updatedAt

  // Replace-with-history: a replaced file points at the record that superseded
  // it, so the current version is supersededById == null; prior versions are
  // reachable via `supersedes`.
  supersededById String?
  supersededBy   FileAttachment?  @relation("FileSupersede", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes     FileAttachment[] @relation("FileSupersede")

  @@index([dealId])
  @@index([buyerId])
}

// ---------------------------------------------------------------------------
// Activity log — pre-rendered summary strings powering the dashboard feed
// ---------------------------------------------------------------------------

model ActivityLog {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventType      String
  dealId         String?
  deal           Deal?         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  buyerId        String?
  buyer          Buyer?        @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  actorUserId    String?
  actor          User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  summary        String
  createdAt      DateTime      @default(now())

  @@index([createdAt])
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Expenses — business expense tracking (feeds Net Profit in Reports)
// ---------------------------------------------------------------------------

// Categories are a table (not an enum) so admins can add/edit/remove them per
// org over time. Defaults are seeded on first access.
model ExpenseCategory {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())

  expenses Expense[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Expense {
  id                String           @id @default(cuid())
  organizationId    String
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Creator of the record — set from the session, never editable.
  userId            String?
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  date              DateTime
  amount            Float
  categoryId        String?
  category          ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  notes             String?
  reimbursed        Boolean          @default(false)
  reimbursementDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([categoryId])
  @@index([date])
}

// ---------------------------------------------------------------------------
// Research & Market Intelligence — public-records activity (recorded mineral
// instruments, leasing documents, drilling permits) imported per organization.
// Texas-first, nationwide-ready: geography is stored as generic state/county
// plus optional TX abstract/survey and non-TX section-township-range (`trs`),
// so new states need a source adapter, not a schema change.
// ---------------------------------------------------------------------------

// Coarse class used for trend aggregation: ownership transfers vs leasing.
enum ResearchDocClass {
  TRANSACTION
  LEASE
}

// Normalized instrument type (raw recorded type string is kept alongside).
enum ResearchDocType {
  MINERAL_DEED
  ROYALTY_DEED
  MINERAL_CONVEYANCE
  OG_CONVEYANCE
  QUITCLAIM_MINERAL_DEED
  WARRANTY_MINERAL_DEED
  ASSIGNMENT
  RESERVATION
  OG_LEASE
  LEASE_MEMO
  LEASE_ASSIGNMENT
  LEASE_RELEASE
  LEASE_AMENDMENT
  LEASE_EXTENSION
  LEASE_RATIFICATION
  OTHER
}

// Well/permit lifecycle stage (union across states; TX W-1 maps onto this).
enum ResearchPermitStatus {
  SUBMITTED
  APPROVED
  SPUDDED
  COMPLETED
  CANCELED
}

enum WellTrajectory {
  VERTICAL
  HORIZONTAL
  DIRECTIONAL
  UNKNOWN
}

enum ResearchIngestKind {
  DOCUMENTS
  PERMITS
  PRODUCTION
}

enum ResearchIngestStatus {
  COMPLETED
  FAILED
}

// A recorded county instrument related to mineral ownership or leasing.
model ResearchDocument {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  state  String // "TX"
  county String

  docTypeRaw String // instrument type exactly as recorded
  docType    ResearchDocType
  docClass   ResearchDocClass

  instrumentNumber String?
  volume           String?
  page             String?
  recordingDate    DateTime
  effectiveDate    DateTime?

  grantor     String?
  grantee     String?
  // Normalized (uppercased, punctuation/suffix-stripped) for grouping/rankings.
  grantorNorm String?
  granteeNorm String?

  // Geography below county level. TX: abstract/survey. Elsewhere: trs
  // ("Sec 12 T2N R3W") or whatever the state's cadastral unit is.
  abstractId       String?
  survey           String?
  trs              String?
  legalDescription String?

  acreage       Float?
  consideration Float?

  source    String  @default("manual") // adapter key (see domain/researchSources.ts)
  sourceRef String? // row id / document URL at the source

  // Links each record to the import batch (ResearchIngestRun) that created it,
  // so a single import can be deleted without touching other data. Null for
  // records created before batch tracking or by the sample seeder.
  ingestRunId String?
  // Soft-archive (Records bulk "Archive"): hidden from the default list but
  // retained; distinct from deletion.
  archivedAt DateTime?

  createdAt DateTime @default(now())

  @@index([organizationId, state, county, recordingDate])
  @@index([organizationId, docClass, recordingDate])
  @@index([organizationId, granteeNorm])
  @@index([organizationId, grantorNorm])
  @@index([organizationId, abstractId])
  @@index([organizationId, ingestRunId])
}

// A drilling permit / well lifecycle record (TX RRC W-1 and equivalents).
model ResearchPermit {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  state  String
  county String

  apiNumber    String?
  permitNumber String?
  operator     String
  operatorNorm String
  leaseName    String?
  wellName     String?

  status     ResearchPermitStatus @default(SUBMITTED)
  trajectory WellTrajectory       @default(UNKNOWN)

  // Canonical date used for trend bucketing (earliest known lifecycle date).
  activityDate   DateTime
  filedDate      DateTime?
  approvedDate   DateTime?
  spudDate       DateTime?
  completionDate DateTime?

  formation  String?
  field      String?
  totalDepth Float?

  abstractId String?
  survey     String?
  trs        String?
  latitude   Float?
  longitude  Float?

  source    String  @default("manual")
  sourceRef String?

  ingestRunId String?
  archivedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([organizationId, state, county, activityDate])
  @@index([organizationId, operatorNorm])
  @@index([organizationId, activityDate])
  @@index([organizationId, ingestRunId])
}

enum WellStatus {
  PRODUCING
  SHUT_IN
  PLUGGED
  INACTIVE
  UNKNOWN
}

// A producing (or historically producing) well used by the Well Production
// Analysis & Valuation tool. Kept separate from ResearchPermit: permits track
// pre-drill lifecycle events, wells carry the production stream we value.
model ResearchWell {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  apiNumber String? // 10/14-digit API; primary dedupe key when present
  name      String // well name + number, e.g. "SMITH UNIT 1H"
  operator  String?
  leaseName String?
  fieldName String?
  formation String?

  state  String
  county String

  status     WellStatus     @default(UNKNOWN)
  trajectory WellTrajectory @default(UNKNOWN)
  wellType   String? // "OIL" | "GAS" | mixed descriptors as reported

  spudDate      DateTime?
  firstProdDate DateTime?

  abstractId String?
  survey     String?
  trs        String?
  latitude   Float?
  longitude  Float?

  source    String  @default("manual")
  sourceRef String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  production WellProductionMonth[]

  @@unique([organizationId, apiNumber])
  @@index([organizationId, state, county])
  @@index([organizationId, name])
}

// One month of reported production for a well. Volumes are month totals.
model WellProductionMonth {
  id     String       @id @default(cuid())
  wellId String
  well   ResearchWell @relation(fields: [wellId], references: [id], onDelete: Cascade)

  month DateTime // first day of the month, UTC midnight

  oilBbl   Float @default(0)
  gasMcf   Float @default(0)
  nglBbl   Float @default(0)
  waterBbl Float @default(0)
  daysOn   Int?

  source String @default("manual")

  @@unique([wellId, month])
  @@index([wellId, month])
}

// A saved valuation run: the user's assumptions plus a snapshot of computed
// results so past analyses stay stable even as production data grows.
model WellAnalysis {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name    String
  wellIds String[]

  assumptions Json // ValuationAssumptions (domain/valuation.ts)
  results     Json? // ValuationResult snapshot from the last run
  notes       String?

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId, updatedAt])
}

// Provenance for every import (CSV upload today; automated connectors later).
model ResearchIngestRun {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  kind     ResearchIngestKind
  source   String
  state    String?
  county   String?
  filename String?

  rowsTotal    Int @default(0)
  rowsImported Int @default(0)
  rowsSkipped  Int @default(0)
  rowsFailed   Int @default(0)

  status          ResearchIngestStatus @default(COMPLETED)
  error           String?
  createdByUserId String?
  createdAt       DateTime             @default(now())

  @@index([organizationId, createdAt])
}
